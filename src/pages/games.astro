<style>
    .games-page {
        display: flex;
        flex-direction: column;
        gap: 3rem;
    }

    .page-title {
        font-size: 2.5rem;
        font-weight: 700;
        color: #e0e0e0;
        text-align: center;
        margin-bottom: 0.5rem;
    }

    .section {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .section-title {
        font-size: 1.75rem;
        font-weight: 600;
        color: #e0e0e0;
        border-bottom: 2px solid #7c5cfc;
        padding-bottom: 0.5rem;
    }

    .section-subtitle {
        color: #888;
        font-size: 0.95rem;
        margin-top: -0.75rem;
        font-style: italic;
    }

    /* Games Grid - 3 Column Layout */
    .games-grid {
        display: flex;
        gap: 1.5rem;
        align-items: flex-start;
    }

    .games-column {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 1rem;
        min-width: 0;
    }

    /* Game Card */
    .game-card {
        background-color: #1a1a1a;
        border: 1px solid #2a2a2a;
        border-radius: 8px;
        padding: 1.25rem;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        transition: border-color 0.2s ease, transform 0.2s ease;
    }

    .game-card:hover {
        border-color: #7c5cfc;
        transform: translateY(-2px);
    }

    .game-title {
        font-size: 1.1rem;
        font-weight: 600;
        color: #e0e0e0;
        line-height: 1.3;
    }

    .game-note {
        font-size: 0.85rem;
        color: #888;
        font-weight: 400;
    }

    .game-link {
        display: inline-block;
        padding: 0.5rem 1rem;
        border-radius: 6px;
        font-size: 0.9rem;
        font-weight: 500;
        text-decoration: none;
        text-align: center;
        transition: background-color 0.2s ease, color 0.2s ease;
        cursor: pointer;
    }

    .drive-link {
        background-color: #7c5cfc;
        color: #fff;
    }

    .drive-link:hover {
        background-color: #9b82fc;
        color: #fff;
    }

    .itch-link {
        background-color: transparent;
        color: #7c5cfc;
        border: 1px solid #7c5cfc;
    }

    .itch-link:hover {
        background-color: #7c5cfc;
        color: #fff;
    }

    /* Browser Games List */
    .browser-games-list {
        list-style: none;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .browser-games-list li {
        background-color: #1a1a1a;
        border: 1px solid #2a2a2a;
        border-radius: 6px;
        padding: 0.75rem 1rem;
        transition: border-color 0.2s ease;
    }

    .browser-games-list li:hover {
        border-color: #7c5cfc;
    }

    .browser-games-list a {
        color: #e0e0e0;
        text-decoration: none;
        font-size: 1rem;
        display: block;
        transition: color 0.2s ease;
    }

    .browser-games-list a:hover {
        color: #7c5cfc;
    }

    /* Responsive: Tablet (2 columns) */
    @media (max-width: 900px) {
        .games-grid {
            flex-wrap: wrap;
        }

        .games-column {
            flex: 1 1 calc(50% - 0.75rem);
            min-width: calc(50% - 0.75rem);
        }
    }

    /* Responsive: Mobile (1 column) */
    @media (max-width: 600px) {
        .page-title {
            font-size: 2rem;
        }

        .section-title {
            font-size: 1.4rem;
        }

        .games-grid {
            flex-direction: column;
        }

        .games-column {
            flex: 1 1 100%;
            min-width: 100%;
        }

        .game-card {
            padding: 1rem;
        }
    }
</style>
