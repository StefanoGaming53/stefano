---
import Layout from "../layouts/Layout.astro";

const socialLinks = [
    {
        name: "YouTube",
        url: "https://www.youtube.com/@Stefano_Gaming",
        description: "Game trailers, devlogs, and gameplay videos",
        color: "#FF0000",
        icon: "youtube",
    },
    {
        name: "Twitch",
        url: "https://www.twitch.tv/stefano_gamingtv",
        description: "Live game development and gaming streams",
        color: "#9146FF",
        icon: "twitch",
    },
    {
        name: "Twitter / X",
        url: "https://x.com/StefanoGaming53",
        description: "Updates, announcements, and community",
        color: "#1DA1F2",
        icon: "twitter",
    },
];

const gamePlatformLinks = [
    {
        name: "Itch.io",
        url: "https://stefano-gaming.itch.io",
        description: "Play my browser and downloadable games",
        color: "#FA5C5C",
        icon: "itchio",
    },
    {
        name: "Steam",
        url: "https://steamcommunity.com/profiles/76561198966597091/",
        description: "Check out my Steam profile and games",
        color: "#1B2838",
        icon: "steam",
    },
    {
        name: "GDevelop",
        url: "https://gd.games/Stefano_Gaming",
        description: "Games published on the GDevelop platform",
        color: "#3E9A3E",
        icon: "gdevelop",
    },
];

const musicLinks = [
    {
        name: "Spotify",
        url: "https://open.spotify.com/artist/52IwESXoFNackotDmAFHSG?si=N-vuK82TSFC3tooJT_lhaA",
        description: "Listen to my game soundtracks and music",
        color: "#1DB954",
        icon: "spotify",
    },
];

const allSections = [
    { title: "Social & Streaming", links: socialLinks },
    { title: "Game Platforms", links: gamePlatformLinks },
    { title: "Music", links: musicLinks },
];
---

<Layout title="Links | Stefano Gaming">
    <div class="links-page">
        <h1 class="page-title">My Links</h1>
        <p class="page-subtitle">
            Find me across the web — follow, play, and connect
        </p>

        {
            allSections.map((section) => (
                <section class="links-section">
                    <h2 class="section-title">{section.title}</h2>
                    <div class="links-grid">
                        {section.links.map((link) => (
                            <a
                                href={link.url}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="link-card"
                            >
                                <div class="link-card__header">
                                    <div
                                        class={`link-card__icon link-card__icon--${link.icon}`}
                                    >
                                        {link.icon === "youtube" && (
                                            <svg
                                                viewBox="0 0 24 24"
                                                fill="currentColor"
                                                width="28"
                                                height="28"
                                            >
                                                <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z" />
                                            </svg>
                                        )}
                                        {link.icon === "twitch" && (
                                            <svg
                                                viewBox="0 0 24 24"
                                                fill="currentColor"
                                                width="28"
                                                height="28"
                                            >
                                                <path d="M11.571 4.714h1.715v5.143H11.57zm4.715 0H18v5.143h-1.714zM6 0L1.714 4.286v15.428h5.143V24l4.286-4.286h3.428L22.286 12V0zm14.571 11.143l-3.428 3.428h-3.429l-3 3v-3H6.857V1.714h13.714z" />
                                            </svg>
                                        )}
                                        {link.icon === "twitter" && (
                                            <svg
                                                viewBox="0 0 24 24"
                                                fill="currentColor"
                                                width="28"
                                                height="28"
                                            >
                                                <path d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932zM17.61 20.644h2.039L6.486 3.24H4.298z" />
                                            </svg>
                                        )}
                                        {link.icon === "itchio" && (
                                            <svg
                                                viewBox="0 0 24 24"
                                                fill="currentColor"
                                                width="28"
                                                height="28"
                                            >
                                                <path d="M3.13 1.338C2.08 1.96.02 4.328 0 4.95v1.03c0 1.303.978 2.47 2.108 2.47 1.27 0 2.236-1.063 2.236-2.336 0 1.273.89 2.336 2.16 2.336 1.27 0 2.188-1.063 2.188-2.336 0 1.273.958 2.336 2.229 2.336h.042c1.27 0 2.23-1.063 2.23-2.336 0 1.273.917 2.336 2.187 2.336 1.27 0 2.16-1.063 2.16-2.336 0 1.273.967 2.336 2.236 2.336 1.13 0 2.108-1.167 2.108-2.47V4.949c-.02-.62-2.08-2.99-3.13-3.612a84.218 84.218 0 0 0-8.942-.005 84.239 84.239 0 0 0-8.642.005zm5.878 8.482c-.698.282-1.472.458-1.996.458a3.54 3.54 0 0 1-1.283-.248L6.31 20.229c.792.876 4.133 1.276 5.69 1.276 1.558 0 4.898-.4 5.69-1.276l-1.478-10.2a3.54 3.54 0 0 1-1.283.248c-.59 0-1.478-.226-2.233-.533a6.226 6.226 0 0 0-1.078-.356 3.442 3.442 0 0 0-1.078.156c-.49.163-.89.368-1.44.585z" />
                                            </svg>
                                        )}
                                        {link.icon === "steam" && (
                                            <svg
                                                viewBox="0 0 24 24"
                                                fill="currentColor"
                                                width="28"
                                                height="28"
                                            >
                                                <path d="M11.979 0C5.678 0 .511 4.86.022 11.037l6.432 2.658c.545-.371 1.203-.59 1.912-.59.063 0 .125.004.188.006l2.861-4.142V8.91c0-2.495 2.028-4.524 4.524-4.524 2.494 0 4.524 2.031 4.524 4.527s-2.03 4.525-4.524 4.525h-.105l-4.076 2.911c0 .052.004.105.004.159 0 1.875-1.515 3.396-3.39 3.396-1.635 0-3.016-1.173-3.331-2.727L.436 15.27C1.862 20.307 6.486 24 11.979 24c6.627 0 11.999-5.373 11.999-12S18.605 0 11.979 0zM7.54 18.21l-1.473-.61c.262.543.714.999 1.314 1.25 1.297.539 2.793-.076 3.332-1.375.263-.63.264-1.319.005-1.949s-.75-1.121-1.377-1.383c-.624-.26-1.29-.249-1.878-.03l1.523.63c.956.4 1.409 1.5 1.009 2.455-.397.957-1.497 1.41-2.454 1.012H7.54zm11.415-9.303c0-1.662-1.353-3.015-3.015-3.015-1.665 0-3.015 1.353-3.015 3.015 0 1.665 1.35 3.015 3.015 3.015 1.663 0 3.015-1.35 3.015-3.015zm-5.273-.005c0-1.252 1.013-2.266 2.265-2.266 1.249 0 2.266 1.014 2.266 2.266 0 1.251-1.017 2.265-2.266 2.265-1.253 0-2.265-1.014-2.265-2.265z" />
                                            </svg>
                                        )}
                                        {link.icon === "gdevelop" && (
                                            <svg
                                                viewBox="0 0 24 24"
                                                fill="currentColor"
                                                width="28"
                                                height="28"
                                            >
                                                <path d="M2 2v20h20V2H2zm8.002 15.997H5.001V14h2v2h3.001v1.997zm0-7.998H7.001v2h-2V9.003h5.001V12zm6.996 7.998H14v-1.997h3V14h2v3.997h-.002zM16 12v-2.997h-2V12h-2V9.003h2V7h2v2.003h2V12h-2z" />
                                            </svg>
                                        )}
                                        {link.icon === "spotify" && (
                                            <svg
                                                viewBox="0 0 24 24"
                                                fill="currentColor"
                                                width="28"
                                                height="28"
                                            >
                                                <path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z" />
                                            </svg>
                                        )}
                                    </div>
                                    <div class="link-card__info">
                                        <h3 class="link-card__name">
                                            {link.name}
                                        </h3>
                                        <p class="link-card__desc">
                                            {link.description}
                                        </p>
                                    </div>
                                </div>
                                <span class="link-card__action">
                                    Visit
                                    <svg
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        width="16"
                                        height="16"
                                    >
                                        <path d="M5 12h14M12 5l7 7-7 7" />
                                    </svg>
                                </span>
                            </a>
                        ))}
                    </div>
                </section>
            ))
        }

        <section class="links-section links-section--contact">
            <h2 class="section-title">Get In Touch</h2>
            <div class="contact-card">
                <div class="contact-card__icon">
                    <svg
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        width="32"
                        height="32"
                    >
                        <path
                            d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"
                        ></path>
                    </svg>
                </div>
                <div class="contact-card__content">
                    <h3 class="contact-card__title">Email</h3>
                    <p class="contact-card__desc">
                        Questions, suggestions, or just want to say hi?
                    </p>
                </div>
                <a
                    href="mailto:StefanoGaming53@gmail.com"
                    class="contact-card__button"
                >
                    StefanoGaming53@gmail.com
                    <svg
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        width="16"
                        height="16"
                    >
                        <path d="M5 12h14M12 5l7 7-7 7"></path>
                    </svg>
                </a>
            </div>
        </section>
    </div>
</Layout>

<style>
    :root {
        --bg: #000000;
        --card-bg: #0a0a0a;
        --text: #ffffff;
        --muted: #818181;
        --primary: #fe2c00;
        --primary-hover: #8a1800;
        --border: #222222;
    }

    .links-page {
        max-width: 900px;
        margin: 0 auto;
        padding: 1rem 0;
    }

    /* ── Page Header ── */
    .page-title {
        font-size: 2.5rem;
        font-weight: 700;
        color: var(--text);
        text-align: center;
        margin-bottom: 0.5rem;
    }

    .page-subtitle {
        text-align: center;
        color: var(--muted);
        font-size: 1.05rem;
        margin-bottom: 2.5rem;
        line-height: 1.5;
    }

    /* ── Sections ── */
    .links-section {
        margin-bottom: 2.5rem;
    }

    .section-title {
        font-size: 1.15rem;
        font-weight: 600;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.06em;
        margin-bottom: 1rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid var(--border);
    }

    /* ── Links Grid ── */
    .links-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 0.875rem;
    }

    @media (min-width: 640px) {
        .links-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    /* ── Link Card ── */
    .link-card {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        padding: 1.25rem;
        background-color: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 12px;
        text-decoration: none;
        color: var(--text);
        transition:
            transform 0.25s ease,
            border-color 0.25s ease,
            box-shadow 0.25s ease,
            background-color 0.25s ease;
        cursor: pointer;
    }

    .link-card:hover {
        transform: translateY(-4px);
        border-color: var(--primary);
        box-shadow: 0 8px 24px rgba(254, 44, 0, 0.12);
        background-color: #0d0d0d;
    }

    .link-card__header {
        display: flex;
        align-items: flex-start;
        gap: 1rem;
        margin-bottom: 1rem;
    }

    /* ── Icon Container ── */
    .link-card__icon {
        width: 48px;
        height: 48px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        transition: transform 0.25s ease;
    }

    .link-card:hover .link-card__icon {
        transform: scale(1.08);
    }

    .link-card__icon svg {
        display: block;
    }

    .link-card__icon--youtube {
        background: rgba(255, 0, 0, 0.12);
        color: #ff0000;
    }

    .link-card__icon--twitch {
        background: rgba(145, 70, 255, 0.12);
        color: #9146ff;
    }

    .link-card__icon--twitter {
        background: rgba(255, 255, 255, 0.08);
        color: #ffffff;
    }

    .link-card__icon--itchio {
        background: rgba(250, 92, 92, 0.12);
        color: #fa5c5c;
    }

    .link-card__icon--steam {
        background: rgba(27, 40, 56, 0.5);
        color: #66c0f4;
    }

    .link-card__icon--gdevelop {
        background: rgba(62, 154, 62, 0.12);
        color: #3e9a3e;
    }

    .link-card__icon--spotify {
        background: rgba(29, 185, 84, 0.12);
        color: #1db954;
    }

    /* ── Card Info ── */
    .link-card__info {
        flex: 1;
        min-width: 0;
    }

    .link-card__name {
        font-size: 1.15rem;
        font-weight: 600;
        color: var(--text);
        margin: 0 0 0.25rem;
        line-height: 1.3;
    }

    .link-card__desc {
        font-size: 0.85rem;
        color: var(--muted);
        margin: 0;
        line-height: 1.45;
    }

    /* ── Visit Action ── */
    .link-card__action {
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--primary);
        margin-top: 0.5rem;
        transition:
            gap 0.2s ease,
            color 0.2s ease;
    }

    .link-card:hover .link-card__action {
        gap: 0.625rem;
        color: var(--primary-hover);
    }

    /* ── Contact Section ── */
    .links-section--contact {
        margin-top: 3rem;
        margin-bottom: 1rem;
    }

    .contact-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
        padding: 2rem;
        background-color: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 12px;
        text-align: center;
    }

    .contact-card__icon {
        width: 56px;
        height: 56px;
        border-radius: 50%;
        background: rgba(254, 44, 0, 0.1);
        color: var(--primary);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .contact-card__content {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .contact-card__title {
        font-size: 1.15rem;
        font-weight: 600;
        color: var(--text);
        margin: 0;
    }

    .contact-card__desc {
        font-size: 0.9rem;
        color: var(--muted);
        margin: 0;
    }

    .contact-card__button {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.65rem 1.5rem;
        background-color: var(--primary);
        color: #fff;
        font-size: 0.9rem;
        font-weight: 600;
        border-radius: 8px;
        text-decoration: none;
        transition:
            background-color 0.2s ease,
            transform 0.2s ease;
    }

    .contact-card__button:hover {
        background-color: var(--primary-hover);
        color: #fff;
        transform: scale(1.03);
    }

    .contact-card__button:active {
        transform: scale(0.98);
    }

    /* ── Responsive ── */
    @media (max-width: 640px) {
        .page-title {
            font-size: 2rem;
        }

        .page-subtitle {
            font-size: 0.95rem;
        }

        .links-grid {
            gap: 0.75rem;
        }

        .link-card {
            padding: 1rem;
        }

        .link-card__icon {
            width: 42px;
            height: 42px;
        }

        .link-card__name {
            font-size: 1.05rem;
        }

        .contact-card {
            padding: 1.5rem;
        }
    }
</style>
