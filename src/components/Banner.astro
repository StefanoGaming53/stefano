---
import bannersData from "../data/banners.json";

const banners = bannersData.banners;
---

<div id="site-banner" aria-hidden="true"></div>
<script
    type="application/json"
    id="banner-config"
    is:inline
    set:html={JSON.stringify(banners)}
/>

<script>
    interface BannerConfig {
        title: string;
        date: string;
        repeat?: "yearly" | "none";
        type?: "static" | "marquee";
        text: string;
        bgColor?: string;
        textColor?: string;
        duration?: number;
        speed?: number;
    }

    function initBanner() {
        const configEl = document.getElementById("banner-config");
        const bannerEl = document.getElementById("site-banner");
        if (!configEl || !bannerEl) return;

        let banners: BannerConfig[] = [];
        try {
            banners = JSON.parse(configEl.textContent || "[]");
        } catch {
            return;
        }

        const now = new Date();
        const active = banners.find((b) => isBannerActive(b, now));

        if (active) {
            renderBanner(bannerEl, active);
            bannerEl.setAttribute("aria-hidden", "false");
        } else {
            bannerEl.innerHTML = "";
            bannerEl.setAttribute("aria-hidden", "true");
        }
    }

    function isBannerActive(banner: BannerConfig, now: Date): boolean {
        const parts = banner.date.split("-").map(Number);
        const duration = banner.duration ?? 1;

        let start: Date;
        let end: Date;

        if (banner.repeat === "yearly") {
            const [month, day] = parts;
            start = new Date(now.getFullYear(), month - 1, day);
        } else {
            const [year, month, day] = parts;
            start = new Date(year, month - 1, day);
        }

        end = new Date(start);
        end.setDate(end.getDate() + duration);

        return now >= start && now < end;
    }

    function escapeHtml(str: string): string {
        const div = document.createElement("div");
        div.textContent = str;
        return div.innerHTML;
    }

    function escapeAttr(str: string): string {
        return String(str)
            .replace(/&/g, "&amp;")
            .replace(/"/g, "&quot;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;");
    }

    // Repeat the text (with a gap) enough to overflow any viewport, using an
    // even number of units so the -50% translate loop is seamless.
    function buildMarqueeText(text: string): string {
        const unit = text + "\u00A0\u00A0\u00A0\u00A0";
        const minLen = 400;
        let repeats = 1;
        while (unit.length * repeats < minLen) repeats++;
        if (repeats % 2 !== 0) repeats++;
        return unit.repeat(repeats);
    }

    function renderBanner(el: HTMLElement, banner: BannerConfig) {
        const bg = banner.bgColor || "#fe2c00";
        const color = banner.textColor || "#ffffff";

        if (banner.type === "marquee") {
            const speed = banner.speed ?? 18;
            const marqueeText = buildMarqueeText(escapeAttr(banner.text || ""));
            el.innerHTML = `
                <div class="banner-marquee" data-text="${marqueeText}" style="background-color:${bg};color:${color};--banner-duration:${speed}s"></div>
            `;
        } else {
            const staticText = escapeHtml(banner.text || "");
            el.innerHTML = `
                <div class="banner-static" style="background-color:${bg};color:${color}">${staticText}</div>
            `;
        }
    }

    document.addEventListener("astro:page-load", initBanner);
    initBanner();
</script>

<style is:global>
    #site-banner {
        width: 100%;
    }

    .banner-marquee {
        width: 100%;
        overflow: hidden;
        white-space: nowrap;
        padding: 0.5rem 0;
    }

    .banner-marquee::before {
        content: attr(data-text);
        display: inline-block;
        white-space: nowrap;
        font-weight: 700;
        font-size: 0.9rem;
        letter-spacing: 0.04em;
        animation: banner-scroll var(--banner-duration, 18s) linear infinite;
        will-change: transform;
    }

    .banner-marquee:hover::before {
        animation-play-state: paused;
    }

    @keyframes banner-scroll {
        from {
            transform: translateX(0);
        }
        to {
            transform: translateX(-50%);
        }
    }

    .banner-static {
        width: 100%;
        text-align: center;
        font-weight: 600;
        font-size: 0.9rem;
        padding: 0.625rem 1rem;
    }

    @media (max-width: 640px) {
        .banner-marquee::before,
        .banner-static {
            font-size: 0.8rem;
        }
    }
</style>
